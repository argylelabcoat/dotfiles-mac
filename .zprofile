
eval "$(/opt/homebrew/bin/brew shellenv)"

alias ls=lsd
alias ls='lsd'
alias l='lsd --almost-all --long'
alias llm='lsd --timesort --long'
alias lS='lsd --oneline --classic'
alias lt='lsd --tree --depth=2'
alias ll='lsd -l'
alias brew-dump='brew bundle dump --force'

